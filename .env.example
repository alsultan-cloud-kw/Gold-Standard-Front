# API (production default in code: https://api.goldstandardkw.com/api)
# For /gs-kyc local testing, run Django and use:
# VITE_BACKEND_API_URL=http://127.0.0.1:8000/api
# VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Clerk — Google / Apple sign-in (Clerk app: app_3EwkN0HFuTJjZWV2u90maxU8XXg)
# Dashboard → API Keys → React → Publishable key (production: pk_live_...)
# Apple + Google OAuth credentials go in Clerk Dashboard → SSO connections only — NOT in .env here
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Google One Tap — same Web client ID as Clerk Dashboard → Google → Use custom credentials.
# In Google Cloud Console, add Authorized JavaScript origins: https://www.goldstandardkw.com and https://goldstandardkw.com
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Optional — only if clerk subdomain DNS is NOT verified (requires api/clerk-fapi on Vercel):
# VITE_CLERK_PROXY_URL=/__clerk

# Cloudflare Turnstile — public site key (widget on login/register)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADkAZ-QKorXrXCKv
